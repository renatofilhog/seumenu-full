# =============================================================
# SeúMenu — Production Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# Run scripts/setup.sh to generate this automatically.
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=seumenu
POSTGRES_PASSWORD=CHANGE_ME_GENERATED_BY_SETUP
POSTGRES_DB=seumenu

# --- JWT ---
JWT_SECRET=CHANGE_ME_GENERATED_BY_SETUP
JWT_EXPIRES_IN=7d

# --- AWS S3 ---
S3_REGION=us-east-1
S3_BUCKET=storage-seumenu
S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY_ID
S3_SECRET_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_READ=false
S3_AUTO_CREATE_BUCKET=false
S3_PRESIGN_EXP_SECONDS=86400
STORAGE_MAX_FILE_SIZE_MB=10

# --- Tenant Routing ---
# Comma-separated base hosts where slug-based routing (/slug/menu) is enabled
TENANT_SLUG_BASE_HOSTS=app.seumenu.io
